includeConfig 'nxf.config'

env {
  CMD_ANNOTSV = "apptainer exec --no-mount home ${APPTAINER_CACHEDIR}/annotsv-3.5.5+build.1.sif AnnotSV"
  CMD_CAPICE = "apptainer exec --no-mount home ${APPTAINER_CACHEDIR}/capice-5.1.2+build.1.sif capice"
  CMD_GADO = "apptainer exec --no-mount home ${APPTAINER_CACHEDIR}/gado-1.0.3+build.3.sif"
  CMD_VEP = "apptainer exec --no-mount home ${APPTAINER_CACHEDIR}/vep-115.2+d7cffe1.sif vep"
  CMD_FILTERVEP = "apptainer exec --no-mount home ${APPTAINER_CACHEDIR}/vep-115.2+d7cffe1.sif filter_vep"
  CMD_STRANGER = "apptainer exec --no-mount home ${APPTAINER_CACHEDIR}/stranger-0.9.3+build.1.sif stranger"
  CMD_VCFREPORT="apptainer exec --no-mount home ${APPTAINER_CACHEDIR}/vcf-report-8.2.4.sif"
  CMD_VCFDECISIONTREE = "apptainer exec --no-mount home ${APPTAINER_CACHEDIR}/vcf-decision-tree-6.0.2.sif"
  CMD_VCFINHERITANCEMATCHER = "apptainer exec --no-mount home ${APPTAINER_CACHEDIR}/vcf-inheritance-matcher-4.0.1.sif"

  // workaround for SAMtools https://github.com/samtools/samtools/issues/1366#issuecomment-769170935
  REF_PATH = ":"
}

process {
  withLabel: 'bed_filter' {
    cpus   = 2
    memory = { meta.project.sequencing_method == "WGS" ? 64.MB : 32.MB }
    time   = 15.m
  }

  withLabel: 'cram_validate' {
    cpus   = { meta.project.sequencing_method == "WGS" ? 3 : 2 }
    memory = { meta.project.sequencing_method == "WGS" ? 1.GB : 512.MB }
    time   = { meta.project.sequencing_method == "WGS" ? 1.h : 15.m }
  }

  withLabel: 'gado' {
    cpus   = 2
    memory = 1.GB
    time   = 15.m
  }

  withLabel:'vcf_annotate' {
    cpus = 4
    memory = { meta.project.sequencing_method == "WGS" ? 16.GB : 4.GB }
    time = { meta.project.sequencing_method == "WGS" ? 4.h : 1.h }
  }

  withLabel: 'vcf_annotate_publish' {
    cpus   = 2
    memory = 64.MB
    time   = 15.m
  }

  withLabel: 'vcf_classify_publish' {
    cpus   = 2
    memory = 64.MB
    time   = { meta.project.sequencing_method == "WGS" ? 1.h : 15.m }
  }

  withLabel: 'vcf_classify' {
    cpus   = 2
    memory = { meta.project.sequencing_method == "WGS" ? 2.GB : 1.GB }
    time   = 15.m
  }

  withLabel: 'vcf_classify_samples' {
    cpus   = 2
    memory = { meta.project.sequencing_method == "WGS" ? 512.MB : 256.MB }
    time   = 15.m
  }

  withLabel: 'vcf_classify_samples_publish' {
    cpus   = 2
    memory = 64.MB
    time   = 15.m
  }

  withLabel: 'vcf_concat' {
    cpus   = 2
    memory = { meta.project.sequencing_method == "WGS" ? 64.MB : 32.MB }
    time   = 15.m
  }

  withLabel: 'vcf_filter' {
    cpus   = 2
    memory = { meta.project.sequencing_method == "WGS" ? 256.MB : 128.MB }
    time   = 15.m
  }

  withLabel: 'vcf_filter_samples' {
    cpus   = 2
    memory = { meta.project.sequencing_method == "WGS" ? 64.MB : 32.MB }
    time   = 15.m
  }

  withLabel: 'vcf_inheritance' {
    cpus   = 2
    memory = { meta.project.sequencing_method == "WGS" ? 2.GB : 1.GB }
    time   = 15.m
  }

  withLabel: 'vcf_liftover' {
    cpus   = 2
    memory = 4.GB
    time   = 15.m
  }

  withLabel: 'vcf_normalize' {
    cpus   = { meta.project.sequencing_method == "WGS" ? 4 : 2 } 
    memory = { meta.project.sequencing_method == "WGS" ? 512.MB : 256.MB }
    time   = 15.m
  }

  withLabel: 'vcf_report' {
    cpus   = 2
    memory = { meta.project.sequencing_method == "WGS" ? 8.GB : 4.GB }
    time   = { meta.project.sequencing_method == "WGS" ? 30.m : 15.m }
  }

  withLabel: 'vcf_slice' {
    cpus   = 4
    memory = 2.GB
    time   = 15.m
  }

  withLabel: 'vcf_split' {
    cpus   = 2
    memory = 64.MB
    time   = 15.m
  }

  withLabel: 'vcf_validate' {
    cpus = { meta.project.sequencing_method == "WGS" ? 3 : 2 }
    memory = 100.MB
    time = 30.m
  }
}

params {
  vcf {  
    start = "" // allowed values: [normalize, annotate, classify, filter, inheritance, classify_samples, filter_samples]

    annotate {
      annotsv_cache_dir = "${VIP_DIR_DATA}/resources/annotsv/v3.5.5"
      ensembl_gene_mapping = "${VIP_DIR}/resources/biomart_ensembl_entrez_mapping.txt"

      gado_genes = "${VIP_DIR_DATA}/resources/gado/v1.0.4_HPO_v2024-08-13/genesProteinCoding.txt"
      gado_hpo = "${VIP_DIR_DATA}/resources/gado/v1.0.4_HPO_v2024-08-13/hp.obo"
      gado_predict_info = "${VIP_DIR_DATA}/resources/gado/v1.0.4_HPO_v2024-08-13/HPO_2024_08_13_prediction_info.txt.gz"
      gado_predict_matrix = "${VIP_DIR_DATA}/resources/gado/v1.0.4_HPO_v2024-08-13/HPO_2024_08_13_prediction_matrix"
      vep_buffer_size = 1000
      vep_cache_dir = "${VIP_DIR_DATA}/resources/vep/cache"
      vep_plugin_annotsv_columns = "AnnotSV_ranking_score;AnnotSV_ranking_criteria;ACMG_class;Gene_name;RE_gene"
      vep_plugin_dir = "${VIP_DIR}/resources/vep/plugins"
      vep_plugin_hpo = "${VIP_DIR_DATA}/resources/hpo_20240813.tsv"
      vep_plugin_inheritance = "${VIP_DIR_DATA}/resources/inheritance_20250411.tsv"
      vep_plugin_spliceai_enabled = true
      vep_plugin_vkgl_mode = 1
      vep_plugin_green_db_enabled = false
      vep_additional_plugins = "" //additional VEP plugins and their arguments, multiple plugins can be separated with ';'

      GRCh38 {
        capice_model = "${VIP_DIR_DATA}/resources/GRCh38/capice_model_v5.1.2_v6.ubj"
        stranger_catalog = "${VIP_DIR_DATA}/resources/GRCh38/strs_20260319.stranger.json"
        vep_custom_phylop = "${VIP_DIR_DATA}/resources/GRCh38/hg38.phyloP100way.bw"
        vep_plugin_apogee = "${VIP_DIR_DATA}/resources/GRCh38/apogee2_scores_20260414.tsv.gz"
        vep_plugin_clinvar = "${VIP_DIR_DATA}/resources/GRCh38/clinvar_20251201_stripped.tsv.gz"
        vep_plugin_gnomad = "${VIP_DIR_DATA}/resources/GRCh38/gnomad.total.v4.1.sites.stripped-v3.tsv.gz"
        vep_plugin_hmtvar = "${VIP_DIR_DATA}/resources/GRCh38/hmtvar_trna_scores.tsv.gz"
        vep_plugin_mitotip = "${VIP_DIR_DATA}/resources/GRCh38/mitotip_scores_20251118.tsv.gz"
        vep_plugin_spliceai_indel = "${VIP_DIR_DATA}/resources/GRCh38/spliceai_scores.masked.indel.hg38.vcf.gz"
        vep_plugin_spliceai_snv = "${VIP_DIR_DATA}/resources/GRCh38/spliceai_scores.masked.snv.hg38.vcf.gz"
        vep_plugin_utrannotator = "${VIP_DIR_DATA}/resources/GRCh38/uORF_5UTR_PUBLIC.txt"
        vep_plugin_vkgl = "${VIP_DIR_DATA}/resources/GRCh38/vkgl_consensus_20250701.tsv"
        vep_plugin_alphscore = "${VIP_DIR_DATA}/resources/GRCh38/AlphScore_final_20230825_stripped_GRCh38.tsv.gz"
        vep_plugin_ncer = "${VIP_DIR_DATA}/resources/GRCh38/GRCh38_ncER_perc.bed.gz"
        vep_plugin_green_db = "${VIP_DIR_DATA}/resources/GRCh38/GRCh38_GREEN-DB.bed.gz"
        vep_plugin_fathmm_MKL_scores = "${VIP_DIR_DATA}/resources/GRCh38/GRCh38_FATHMM-MKL_NC.tsv.gz"
        vep_plugin_ReMM_scores = "${VIP_DIR_DATA}/resources/GRCh38/ReMM.v0.4.hg38.tsv.gz"
      }
    }

    classify {
      annotate_path = 1
			metadata = "${VIP_DIR}/resources/field_metadata.json"

      GRCh38 {
        decision_tree = "${VIP_DIR}/resources/decision_tree_GRCh38.json"
      }
    }

    classify_samples {
      annotate_path = 1
			metadata = "${VIP_DIR}/resources/field_metadata.json"

      GRCh38 {
        decision_tree = "${VIP_DIR}/resources/decision_tree_samples.json"
      }
    }

    filter {
      classes = "VUS,LP,P"
      consequences = true
    }

    filter_samples {
      classes = "U1,U2"
    }

    normalize {
      allow_invalid_ref = false //Throw error by default but allow users to choose to change this to a warning.
    }

    report {
      include_crams = true
      max_records = ""
      max_samples = ""
      template = "${VIP_DIR_DATA}/resources/vip-report-template-v8.4.1.html"
      config = "${VIP_DIR}/resources/vcf_report_config.json"
			metadata = "${VIP_DIR}/resources/field_metadata.json"

      GRCh38 {
        genes = "${VIP_DIR_DATA}/resources/GRCh38/GCF_000001405.26_GRCh38_genomic_mapped.gff.gz"
      }
    }
  }
}
