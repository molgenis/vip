includeConfig 'nxf_cram.config'

env {
  CMD_MINIMAP2 = "apptainer exec --no-mount home ${APPTAINER_CACHEDIR}/minimap2-2.31.sif minimap2"
  CMD_FASTP = "apptainer exec --no-mount home ${APPTAINER_CACHEDIR}/fastp-1.1.0.sif fastp"
  CMD_SEQTK = "apptainer exec --no-mount home ${APPTAINER_CACHEDIR}/seqtk-1.5.sif seqtk"
}

process {
  withLabel: 'fastp' {
    cpus   = 4
    memory = { meta.project.sequencing_method == "WGS" ? 20.GB : 2.GB }
    time   = { meta.project.sequencing_method == "WGS" ? 2.h : 30.m }
  }

  withLabel: 'filter_reads' {
    cpus   = 1
    memory = 4.GB
    time   = 4.h
  }

  withLabel: 'minimap2_align' {
    cpus   = { meta.project.sequencing_method == "WGS" ? 16 : 8 }
    memory = { meta.project.sequencing_method == "WGS" ? 32.GB : 16.GB }
    time   = { meta.project.sequencing_method == "WGS" ? 24.h : 1.h }
  }

  withLabel: 'minimap2_align_paired_end' {
    cpus   = { meta.project.sequencing_method == "WGS" ? 16 : 8 }
    memory = { meta.project.sequencing_method == "WGS" ? 32.GB : 16.GB }
    time   = { meta.project.sequencing_method == "WGS" ? 24.h : 1.h }
  }
}

params {
  adaptive_sampling {
    accepted_responses = "SUCCESS"; //Comma separated list, options: SUCCESS,FAILED_READ_FINISHED,FAILED_READ_TOO_LONG
  }
  minimap2 {
    soft_clipping = true;
    nanopore_preset = "lr:hq";
  }

  fastp {
    options = "";
  }

  GRCh38 {
    reference {
      fastaMmi = "${VIP_DIR_DATA}/resources/GRCh38/GCA_000001405.15_GRCh38_no_alt_analysis_set.fna.gz.mmi"
    }
  }
}
