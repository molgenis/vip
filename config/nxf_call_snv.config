includeConfig 'nxf.config'

env {
  CMD_DEEPVARIANT="apptainer exec --no-mount home ${APPTAINER_CACHEDIR}/deepvariant-1.10.0.sif /opt/deepvariant/bin/run_deepvariant"
  CMD_DEEPVARIANT_DEEPTRIO="apptainer exec --no-mount home ${APPTAINER_CACHEDIR}/deepvariant_deeptrio-1.10.0.sif /opt/deepvariant/bin/deeptrio/run_deeptrio"
}

params {
  snv {
    GRCh38 {
        reference {
          haploidContigs = "chrX,chrY,chrY_KI270740v1_random"
          parRegionsBed = "${VIP_DIR_DATA}/resources/GRCh38/GRCh38_PAR_20251126.bed" //from: https://storage.googleapis.com/deepvariant/case-study-testdata/GRCh38_PAR.bed
        }
    }
    deeptrio {
      illumina {
        WES {
          model_name="WES"
        }
        WGS {
          model_name="WGS"
        }
      }
      nanopore {
        model_name="ONT"
      }
      pacbio_hifi {
        model_name="PACBIO"
      }
    }
    deepvariant {
      illumina {
        WES {
          model_name="WES"
        }
        WGS {
          model_name="WGS"
        }
      }
      nanopore {
        model_name="ONT_R104"
      }
      pacbio_hifi {
        model_name="PACBIO"
      }
    }
    glnexus {
      WES {
        preset="DeepVariantWES"
      }
      WGS {
        preset="DeepVariantWGS"
      }
    }
    whatshap {
      output_read_list = ""
      algorithm = "whatshap"
      internal_downsampling = 15
      mapping_quality = 20
      only_snvs = false
      ignore_read_groups = false
      error_rate = 0.15
      maximum_error_rate = 0.25
      threshold = 1000000
      negative_threshold = 1000
      distrust_genotypes = false
      include_homozygous = false
      default_gq = 30
      gl_regularizer = ""
      changed_genotype_list = ""
      recombination_list = ""
      recombrate = 1.26
      genmap = ""
      no_genetic_haplotyping = false
      use_ped_samples = false
      use_supplementary = false
      supplementary_distance = 100000
    }
  }
}

process {
  withLabel: 'concat_snv_vcf' {
    cpus   = 2
    memory = 3.GB
    time   = 15.m
  }

  withLabel: 'deepvariant_call' {
    cpus   = 4
    memory = { 4.GB * task.cpus }
    time   = { meta.project.sequencing_method == "WGS" ? 12.h : 6.h }
  }

  withLabel: 'deepvariant_call_duo' {
    cpus   = 4
    memory = { 8.GB * task.cpus }
    time   = { meta.project.sequencing_method == "WGS" ? 24.h : 12.h }
  }

  withLabel: 'deepvariant_call_trio' {
    cpus   = 4
    memory = { 8.GB * task.cpus }
    time   = { meta.project.sequencing_method == "WGS" ? 24.h : 12.h }
  }

  withLabel: 'deepvariant_concat_gvcfs' {
    cpus   = 4
    memory = 2.GB
    time   = 30.m
  }

  withLabel: 'deepvariant_concat_vcfs' {
    cpus   = 4
    memory = 2.GB
    time   = 30.m
  }

  withLabel: 'deepvariant_joint_call' {
    cpus   = 2
    memory = 2.GB
    time   = 15.m
  }

  withLabel: 'publish_gvcf' {
    cpus   = 2
    memory = 3.GB
    time   = 15.m
  }

  withLabel: 'whatshap' {
    cpus   = 2
    memory = 2.GB
    time   = 1.h
  }
}