Bootstrap: localimage
From: sif/build/python-3.11.14.sif

%help
   Spectre is a long read copy number variation (CNV) caller.

%post
    apt-get update > /dev/null
    apt-get install git > /dev/null

    # --only-binary :all: : disable all source packages. packages without binary distributions will fail to install
    # install fixed versions for https://github.com/fritzsedlazeck/Spectre/blob/905809435a6bb00aa413a4cf4d4424365112a0af/requirements.txt
    pip install --only-binary :all: pysam==0.22.1 numpy==1.24.4 pandas==2.0.3 matplotlib==3.7.5 scipy==1.10.1
    pip install "spectre-cnv @ git+https://github.com/fritzsedlazeck/Spectre.git@905809435a6bb00aa413a4cf4d4424365112a0af"

    # cleanup
    apt-get purge git > /dev/null
    apt-get autoremove > /dev/null
    rm -rf /var/lib/apt/lists/*

%runscript
    exec spectre "$@"

%test
    set -euo pipefail
    spectre --help > /dev/null
