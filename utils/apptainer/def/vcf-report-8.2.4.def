Bootstrap: localimage
From: sif/build/openjdk-25.sif

%help
    Command-line application to generate a report for any VCF (Variant Call Format) file based on a report template.
    Usage: java -jar /opt/vcf-report/lib/vcf-report.jar

%post
    version_major=8
    version_minor=2
    version_patch=4

    # install
    apk add --virtual=.build-dependencies curl

    mkdir -p /opt/vcf-report/lib
    curl --fail --silent --show-error --location --output /opt/vcf-report/lib/vcf-report.jar "https://github.com/molgenis/vip-report/releases/download/v${version_major}.${version_minor}.${version_patch}/vcf-report.jar"
    echo "e12a60fc3cde232758bd0979fa9557a9e9a5c31b90c9f5201f41be8b514fe827  /opt/vcf-report/lib/vcf-report.jar" | sha256sum -c

    # cleanup
    apk del .build-dependencies
    rm -rf /var/cache/apk/*

%runscript
    exec java -jar /opt/vcf-report/lib/vcf-report.jar "$@"

%test
    set -euo pipefail
    java -jar /opt/vcf-report/lib/vcf-report.jar --version > /dev/null
