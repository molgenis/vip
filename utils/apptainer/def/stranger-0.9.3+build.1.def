Bootstrap: localimage
From: sif/build/python-3.11.14.sif

%help
   Annotates STR output files with the pathologic implications of the repeat sizes.

%post
    version_major=0
    version_minor=9
    version_patch=3

		pip install stranger==${version_major}.${version_minor}.${version_patch}

%runscript
    exec stranger "$@"

%test
    set -euo pipefail
    stranger --version > /dev/null