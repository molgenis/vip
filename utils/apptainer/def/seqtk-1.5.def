Bootstrap: localimage
From: sif/build/alpine-3.23.3.sif
Stage: build

%post
    version_major=1
    version_minor=5

    apk add --repository http://dl-cdn.alpinelinux.org/alpine/edge/community curl build-base zlib-dev bzip2-dev xz-dev libdeflate-dev
    
    # download
    curl --fail --silent --show-error --location --output seqtk.tar.gz "https://github.com/lh3/seqtk/archive/refs/tags/v${version_major}.${version_minor}.tar.gz"
    echo "384aa1e3cecf4f70403839d586cbb29d469b7c6f773a64bc5af48a6e4b8220a6  seqtk.tar.gz" | sha256sum -c

    # install
    tar --extract --gzip --file=seqtk.tar.gz
    mv seqtk-${version_major}.${version_minor} seqtk
    cd seqtk
    make --silent

Bootstrap: localimage
From: sif/build/alpine-3.23.3.sif
Stage: final

%help
    Seqtk is a fast and lightweight tool for processing sequences in the FASTA or FASTQ format.

%files from build
    /seqtk/seqtk /usr/local/bin/seqtk

%post
    apk add --repository http://dl-cdn.alpinelinux.org/alpine/edge/community zlib libbz2 xz-libs libdeflate
    chmod +x /usr/local/bin/seqtk

%runscript
    exec seqtk "$@"

# seqtkpicard returns 'exit 1' on '--help' and '--version' calls, no straightforward way to %test if executable is working
