Bootstrap: localimage
From: sif/build/alpine-3.23.3.sif
Stage: build

%post
    version_major=1
    version_minor=23
    version_patch=1

    apk add --repository http://dl-cdn.alpinelinux.org/alpine/edge/community curl build-base zlib-dev bzip2-dev xz-dev libdeflate-dev
    
    # download
    curl --fail --silent --show-error --location --output bcftools-${version_major}.${version_minor}.${version_patch}.tar.bz2 https://github.com/samtools/bcftools/releases/download/${version_major}.${version_minor}.${version_patch}/bcftools-${version_major}.${version_minor}.${version_patch}.tar.bz2
    echo "01899a46f9420cdc1385d52fcfc84cce2806f9c996b787081a90d7dfc85eafa3  bcftools-${version_major}.${version_minor}.${version_patch}.tar.bz2" | sha256sum -c

    # install
    tar xf bcftools-${version_major}.${version_minor}.${version_patch}.tar.bz2
    cd bcftools-${version_major}.${version_minor}.${version_patch}
    ./configure --silent --disable-libcurl --disable-gcs --disable-s3 --without-curses --disable-ref-cache
    make --silent
    make --silent install

Bootstrap: localimage
From: sif/build/alpine-3.23.3.sif
Stage: final

%help
    BCFtools - utilities for variant calling and manipulating VCFs and BCFs

%files from build
    /usr/local/bin/bcftools
    /usr/local/libexec/bcftools

%post
    apk add --repository http://dl-cdn.alpinelinux.org/alpine/edge/community zlib libbz2 xz-libs libdeflate

%runscript
    exec bcftools "$@"

%test
    set -euo pipefail
    bcftools --version > /dev/null
