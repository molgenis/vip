Bootstrap: localimage
From: sif/build/alpine-3.23.3.sif
Stage: build

%post
    version_major=2
    version_minor=30

    apk add --repository http://dl-cdn.alpinelinux.org/alpine/edge/community curl build-base zlib-dev bzip2-dev libdeflate-dev

    # download
    curl --fail --silent --show-error --location --output minimap2-${version_major}.${version_minor}.tar.bz2 https://github.com/lh3/minimap2/releases/download/v${version_major}.${version_minor}/minimap2-${version_major}.${version_minor}.tar.bz2
    echo "f21b5fc2f8fcd02b88bf0ab9a76ad968d59dc67ac384af31ab074393d9e2c1f0  minimap2-${version_major}.${version_minor}.tar.bz2" | sha256sum -c

    # install
    tar xf minimap2-${version_major}.${version_minor}.tar.bz2
    (cd minimap2-${version_major}.${version_minor} && make --silent)
    mv /minimap2-${version_major}.${version_minor}/minimap2 /usr/local/bin

Bootstrap: localimage
From: sif/build/alpine-3.23.3.sif
Stage: final

%help
    Minimap2 is a versatile sequence alignment program that aligns DNA or mRNA sequences against a large reference database.

%files from build
    /usr/local/bin/minimap2

%post
    apk add --repository http://dl-cdn.alpinelinux.org/alpine/edge/community zlib libdeflate

%test
    set -euo pipefail
    minimap2 --help > /dev/null 2>&1

%runscript
    exec minimap2 "$@"
