Bootstrap: localimage
From: sif/build/openjdk-25.sif

%help
    Command-line application to converts the omim 'genemap2.txt' to a tab separated file that can be used by the VEP Inheritance Plugin.
    Usage: java -jar /opt/vcf-inheritance/lib/genemap-mapper

%post
    version_major=3
    version_minor=2
    version_patch=2

    # install
    apk add --virtual=.build-dependencies curl

    mkdir -p /opt/vcf-inheritance/lib
    curl --fail --silent --show-error --location --output /opt/vcf-inheritance/lib/genemap-mapper.jar "https://github.com/molgenis/vip-inheritance/releases/download/v${version_major}.${version_minor}.${version_patch}/genemap-mapper.jar"
    echo "68494f6a76fa762fb9db3486f920729634498ca74fa000d8fc94cef17b8b3b00  /opt/vcf-inheritance/lib/genemap-mapper.jar" | sha256sum -c

    # cleanup
    apk del .build-dependencies
    rm -rf /var/cache/apk/*

%runscript
    exec java -jar /opt/vcf-inheritance/lib/genemap-mapper.jar "$@"

%test
    set -euo pipefail
    java -jar /opt/vcf-inheritance/lib/genemap-mapper.jar --version > /dev/null
