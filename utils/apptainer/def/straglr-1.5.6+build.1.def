Bootstrap: localimage
From: sif/build/python-3.11.14.sif

%post
    apt-get update > /dev/null
    apt-get install build-essential zlib1g-dev libdeflate-dev curl git > /dev/null
    apt-get install ncbi-blast+ zlib1g libdeflate0 > /dev/null

    mkdir -p /opt/trf/
    curl --fail --silent --show-error --location --output /opt/trf/trf "https://github.com/Benson-Genomics-Lab/TRF/releases/download/v4.09.1/trf409.linux64"
    chmod +x /opt/trf/trf

    pip install "straglr @ git+https://github.com/bcgsc/straglr.git@v1.5.6"

    # cleanup
    apt-get purge build-essentials zlib1g-dev libdeflate-dev curl git > /dev/null
    apt-get autoremove > /dev/null
    rm -rf /var/lib/apt/lists/*

%environment
   PATH=$PATH:/opt/trf

%help
    Long-read-based human genomic short tandem repeat detection.

