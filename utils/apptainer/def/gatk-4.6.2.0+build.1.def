Bootstrap: localimage
From: sif/build/debian-13.3.sif

%help
    Genome Analysis Toolkit - Variant Discovery in High-Throughput Sequencing Data.

%post
    version=4.6.2.0

    # install
    apt-get update > /dev/null
    apt-get install unzip curl libgomp1 openjdk-25-jre > /dev/null

    mkdir -p /opt/gatk/lib
    curl -Ls -o gatk.zip "https://github.com/broadinstitute/gatk/releases/download/${version}/gatk-${version}.zip"
    echo "32d2f90bf13fcb3a8ac765bb2cb8ec1fc9a6cc447055d0156bd1db2092d4e3e8  gatk.zip" | sha256sum -c
    unzip -p gatk.zip "gatk-${version}/gatk-package-${version}-local.jar" > /opt/gatk/lib/gatk.jar

    # cleanup
    rm -rf /var/lib/apt/lists/*

%runscript
    exec java -jar /opt/gatk/lib/gatk.jar "$@"

%test
    set -euo pipefail
    java -jar /opt/gatk/lib/gatk.jar --version > /dev/null
